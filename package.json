{
  "name": "gamesung",
  "version": "0.0.1",
  "private": true,
  "description": "An open-source platform for creating, building, and sharing games",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev:web": "pnpm --filter @gamesung/web dev",
    "dev:server": "pnpm --filter @gamesung/server dev",
    "dev": "pnpm run dev:web",
    "build": "pnpm --filter @gamesung/web build",
    "start": "pnpm --filter @gamesung/web start",
    "lint": "pnpm run lint:web",
    "lint:web": "pnpm --filter @gamesung/web lint",
    "typecheck": "pnpm run typecheck:web",
    "typecheck:web": "pnpm --filter @gamesung/web typecheck"
  }
}
